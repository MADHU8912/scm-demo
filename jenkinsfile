pipeline {
    agent any

    stages {
        stage('Checkout SCM') {
            steps {
                echo 'SCM step completed'
            }
        }

        stage('Check Files') {
            steps {
                bat 'dir'
            }
        }

        stage('Build Report') {
            steps {
                bat 'echo SCM pipeline build successful > build-report.txt'
                bat 'type build-report.txt'
            }
        }
    }
}
